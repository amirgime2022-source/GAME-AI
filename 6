import React, { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import ContentCard from '@/components/ContentCard';
import AIChat from '@/components/AIChat';
import { Gamepad2, Cpu, Sparkles } from 'lucide-react';

export default function Home() {
  const [contents, setContents] = useState([]);
  const [loading, setLoading] = useState(true);
  const [filter, setFilter] = useState('all');

  useEffect(() => {
    base44.entities.GameContent.list('-created_date', 50)
      .then(setContents)
      .finally(() => setLoading(false));
  }, []);

  const categories = ['all', ...Array.from(new Set(contents.map(c => c.category).filter(Boolean)))];
  const filtered = filter === 'all' ? contents : contents.filter(c => c.category === filter);

  return (
    <div className="min-h-screen">
      <section className="relative overflow-hidden grid-bg border-b border-border/50">
        <div className="absolute inset-0 bg-gradient-to-b from-primary/5 via-transparent to-background" />
        <div className="relative max-w-7xl mx-auto px-4 sm:px-6 py-20 text-center">
          <div className="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-primary/30 bg-primary/5 mb-6">
            <Sparkles className="w-4 h-4 text-primary" />
            <span className="text-sm text-primary font-medium">دنیای هوش مصنوعی در بازی</span>
          </div>
          <h1 className="font-display text-4xl md:text-6xl font-black mb-4">
            <span className="neon-text text-primary">Game</span><span className="text-foreground">AI</span>
          </h1>
          <p className="text-lg text-muted-foreground max-w-2xl mx-auto mb-8">
            جدیدترین اخبار، آموزش‌ها و ابزارهای هوش مصنوعی در دنیای ماینکرفت و بازی‌ها
          </p>
          <div className="flex gap-4 justify-center">
            <a href="#chat" className="px-6 py-3 rounded-lg bg-primary text-primary-foreground font-bold hover:opacity-90 transition neon-glow flex items-center gap-2"><Cpu className="w-5 h-5" /> سوال از هوش مصنوعی</a>
            <a href="#content" className="px-6 py-3 rounded-lg border border-border hover:border-primary/50 font-bold transition">مشاهده مطالب</a>
          </div>
        </div>
      </section>

      <section id="content" className="max-w-7xl mx-auto px-4 sm:px-6 py-16">
        <div className="flex flex-wrap items-center justify-between gap-4 mb-8">
          <h2 className="font-heading text-2xl md:text-3xl font-bold">آخرین مطالب</h2>
          <div className="flex gap-2 flex-wrap">
            {categories.map(cat => (
              <button key={cat} onClick={() => setFilter(cat)} className={`px-4 py-2 rounded-lg text-sm font-medium transition ${filter === cat ? 'bg-primary text-primary-foreground' : 'bg-muted text-muted-foreground hover:text-foreground'}`}>{cat === 'all' ? 'همه' : cat}</button>
            ))}
          </div>
        </div>
        {loading ? (
          <div className="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {[1, 2, 3, 4, 5, 6].map(i => <div key={i} className="h-80 rounded-xl border border-border/50 bg-card animate-pulse" />)}
          </div>
        ) : filtered.length === 0 ? (
          <div className="text-center py-16 text-muted-foreground">
            <Gamepad2 className="w-16 h-16 mx-auto mb-4 opacity-30" />
            <p>هنوز مطلبی منتشر نشده است.</p>
          </div>
        ) : (
          <div className="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {filtered.map(item => <ContentCard key={item.id} item={item} />)}
          </div>
        )}
      </section>

      <section id="chat" className="max-w-4xl mx-auto px-4 sm:px-6 py-16">
        <AIChat />
      </section>
    </div>
  );
}
